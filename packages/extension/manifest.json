{
  "manifest_version": 3,
  "name": "BrowserUse",
  "short_name": "BrowserUse",
  "version": "0.5.1",
  "description": "Lets a local MCP server (Claude Code, etc.) drive your logged-in Chrome. Loopback-only. No telemetry.",
  "author": "Marco Bazzani",
  "homepage_url": "https://github.com/marcobazzani/BrowserUse",
  "permissions": ["tabs", "tabGroups", "scripting", "debugger", "storage", "activeTab", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "src/background.ts", "type": "module" },
  "action": { "default_popup": "src/popup/index.html", "default_icon": "icons/icon-128.png" },
  "icons": { "128": "icons/icon-128.png" }
}
